{
  "namespace": "workshop",
  "plugin": {
    "name": "workshop",
    "version": "0.1.0",
    "description": "Workshop harness — agnostic AI coding tooling (plan/work/review/storm/setup), generated for Claude Code and Codex.",
    "author": { "name": "Seven Hills Technology", "url": "https://github.com/seven-hills-technology" },
    "license": "MIT"
  },
  "marketplace": {
    "name": "workshop-marketplace",
    "owner": { "name": "Seven Hills Technology", "url": "https://github.com/seven-hills-technology" },
    "description": "Local marketplace for the Harness Engineering Workshop plugin."
  },
  "toolVersions": {
    "lavishAxi": "0.1.31",
    "playwrightCli": "latest"
  },
  "targets": {
    "claude": {
      "pluginDir": "plugins/workshop",
      "marketplaceFile": ".claude-plugin/marketplace.json",
      "contextFile": "CLAUDE.md"
    },
    "codex": {
      "skillsDir": ".agents/skills",
      "agentsDir": ".codex/agents",
      "configToml": ".codex/config.toml",
      "contextFile": "AGENTS.md",
      "minVersion": "0.12.0"
    }
  }
}
